# UI login
APP_USERNAME=admin
APP_PASSWORD=change-this-password
# Optional, preferred for production: use a password_hash() value instead of APP_PASSWORD.
APP_PASSWORD_HASH=
APP_SESSION_NAME=princess_tracker
APP_TIMEZONE=UTC

# Defaults for price checks
DEFAULT_CRUISE_ID=H630
DEFAULT_CURRENCY_CODE=USD
DEFAULT_GUEST_COUNTRY=US
DEFAULT_GUEST_HOME_CITY=LAX
DEFAULT_GUEST_COUNT=2
DEFAULT_INCLUDE_MISC=1

# Storage. Relative paths are relative to the private app root.
STORAGE_PATH=storage
PRINCESS_HEADERS_PATH=storage/headers.json

# Database: sqlite is simplest. mysql is also supported for Bluehost if SQLite/PDO_SQLITE is unavailable.
DB_DRIVER=sqlite
PRINCESS_DB_PATH=storage/tracker.sqlite

# MySQL alternative. Use only if DB_DRIVER=mysql.
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_DSN=

# Email. On Bluehost, mail is usually easiest. Use sendmail if you prefer.
MAIL_METHOD=mail
MAIL_FROM=princess-tracker@example.com
SENDMAIL_PATH=/usr/sbin/sendmail

# Optional agency defaults from your captured Princess payload.
DEFAULT_AGENCY_ID=DIRECTSG
DEFAULT_AGENCY_STATE_ID=SINGAPORE
DEFAULT_AGENCY_COUNTRY_ID=SG
DEFAULT_AGENCY_HOME_CITY=SIN
DEFAULT_AGENCY_EMAIL=JYEO@CARNIVAL-SG.COM
